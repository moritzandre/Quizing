# Optional Supabase persistence (persistent player profiles + per-player stats).
# Leave BOTH unset and the app runs exactly as before — no backend, no profiles,
# host-local leaderboard only. Set both to enable the player profile layer.
#
# Find these in your Supabase project → Project Settings → API.
# The anon key is publishable/safe to ship in a static frontend; Row Level
# Security (see supabase/migrations/0001_init.sql) is the actual boundary.
#
# Local dev: copy this file to `.env` (gitignored) and fill it in.
# Production (GitHub Pages): set these as repository Actions secrets — the
# deploy workflow injects them into the build.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
